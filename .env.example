# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API (Google)
GEMINI_API_KEY=your_gemini_api_key_here

# NewsAPI
NEWS_API_KEY=your_newsapi_key_here

# MongoDB Connection
